{
  "name": "anvil-interop",
  "version": "1.0.0",
  "description": "Multi-chain Anvil testing environment for ZKsync interoperability",
  "main": "index.ts",
  "scripts": {
    "start": "ts-node index.ts",
    "dev": "ts-node index.ts",
    "build": "tsc",
    "clean": "rm -rf dist outputs chain-states",
    "cleanup": "bash cleanup.sh",
    "step1": "ts-node steps/step1-start-chains.ts",
    "step2": "ts-node steps/step2-deploy-l1.ts",
    "step3": "ts-node steps/step3-register-chains.ts",
    "step4": "ts-node steps/step4-initialize-l2.ts",
    "step5": "ts-node steps/step5-setup-gateway.ts",
    "step6": "ts-node steps/step6-start-settler.ts",
    "test:hardhat": "yarn --cwd ../.. test:hardhat:interop",
    "deploy:test-token": "ts-node deploy-test-token.ts",
    "setup-and-dump": "ts-node setup-and-dump-state.ts",
    "test:v29-to-v31": "ts-node run-v29-to-v31-upgrade-test.ts"
  },
  "keywords": [
    "anvil",
    "zksync",
    "testing",
    "ethereum",
    "interop"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "ethers": "5.7.2",
    "@iarna/toml": "^2.2.5",
    "commander": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
